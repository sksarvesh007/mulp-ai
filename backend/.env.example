# ── LLM / Vision provider ────────────────────────────────────────────────────
# Required only for the LIVE upload path + demo. The 12-case eval runs offline.
# Provider: "deepseek" (text-only, OpenAI-compatible) or "gemini" (multimodal/vision).
LLM_PROVIDER=deepseek

# DeepSeek (text-only, OpenAI-compatible endpoint).
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.lkeap.cloud.tencent.com/v1
DEEPSEEK_MODEL=deepseek-v3-0324

# Gemini (multimodal) — enables the real image/vision extraction path.
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
# Path to the policy file the rule engine reads at runtime (never hardcoded).
# Relative paths resolve against the repo root.
POLICY_FILE=docs/policy_terms.json

# ── Observability ────────────────────────────────────────────────────────────
# Langfuse (GenAI tracing + eval scores). Get keys from your Langfuse project, or use
# the auto-provisioned keys from infra/docker-compose.yml. Set ENABLE_OBSERVABILITY=true.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=claims-backend
ENABLE_OBSERVABILITY=false
