# Copy to `.env` and fill in — or just run ./setup.sh, which generates the secrets,
# detects the VM's public IP, and writes this file for you.

# ── Public URL (REQUIRED) ────────────────────────────────────────────────────
# The address people open in the browser. MUST be how they actually reach the VM.
# For a bare VM:  http://<VM_PUBLIC_IP>:3000   (setup.sh fills the IP automatically)
# With a domain + TLS reverse proxy:  https://langfuse.example.com
NEXTAUTH_URL=http://CHANGE_ME:3000

# ── Login bootstrapped on first boot (share these to grant dashboard access) ──
LANGFUSE_INIT_USER_EMAIL=admin@plum.local
LANGFUSE_INIT_USER_PASSWORD=change-me-strong-password
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_ORG_ID=plum
LANGFUSE_INIT_ORG_NAME=Plum
LANGFUSE_INIT_PROJECT_ID=claims
LANGFUSE_INIT_PROJECT_NAME=Claims

# ── Project API keys the backend uses to send traces ─────────────────────────
# Any pk-lf-/sk-lf- strings (they identify the project in THIS self-hosted DB).
# Put the same values on the Render backend (LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY).
# setup.sh generates fresh ones if left blank.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=

# ── Infrastructure secrets (setup.sh generates strong values) ─────────────────
NEXTAUTH_SECRET=
SALT=
ENCRYPTION_KEY=          # EXACTLY 64 hex chars  ->  openssl rand -hex 32
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_PASSWORD=
